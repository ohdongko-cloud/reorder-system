# Neon PostgreSQL — https://console.neon.tech → 프로젝트 → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# 인증 설정
AUTH_SECRET=랜덤-32자-이상-문자열-여기에-입력   # openssl rand -hex 32
AUTH_PASSWORD=팀에서-사용할-공유-비밀번호

# 배포 URL (로그아웃 리다이렉트용)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
